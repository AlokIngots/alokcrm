DATABASE_URL=sqlite:///./database.db
JWT_SECRET_KEY=change_this_to_a_long_random_secret
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
ALLOW_QUERY_TOKEN=false
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO

# OTP / SMS
SMS_MODE=mock
# SMS_MODE=live requires below keys
SMS_BASE_URL=
SMS_USER=
SMS_PASSWORD=
SMS_SENDER=
SMS_TYPE=
SMS_TEMPLATE_ID=

# SQL echo logs
ECHO_SQL=false
